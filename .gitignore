# Local by Flywheel infrastructure
conf/
logs/

# Local development files
.DS_Store
Thumbs.db
*.log

# Node modules if you have any build processes
node_modules/
npm-debug.log*

# Environment files
.env
.env.local
.env.production

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.temp
*.zip

# Keep only custom WordPress code; ignore core under app/public
app/public/*
!app/public/wp-content/
app/public/wp-admin/
app/public/wp-includes/
app/public/*.php
app/public/wp-config.php

# Simply Static export artifacts (rsync'd into docs/ at deploy time)
app/public/wp-content/uploads/simply-static/

# DB dumps: keep the canonical exported DB in repo
app/sql/*.sql
!app/sql/local.sql
